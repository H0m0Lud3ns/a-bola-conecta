# A Bola Conecta - variaveis de ambiente para deploy isolado
# Nao colocar valores reais neste arquivo.

ABOLA_SITE_DOMAIN=https://abolaconecta.com.br
ABOLA_ALLOW_INDEX=0

# Leads / CRM - fase segura em dry-run.
# DRY_RUN=true registra no log da function e nao envia email real.
DRY_RUN=true
INTERNAL_NOTIFY_EMAIL=contato.gondwana@gmail.com
CRM_ENDPOINT=
CRM_API_KEY=

# Supabase ainda nao definido para A Bola Conecta.
# Se for usado depois, criar projeto/tabelas proprias antes de ativar producao.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Futuro checkout ou links de pagamento.
PAYMENT_PROVIDER=
PAYMENT_PUBLIC_KEY=

# Analytics futuro.
GA_MEASUREMENT_ID=
