{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ],
  "redirects": [
    { "source": "/documental", "destination": "/documentario", "permanent": true },
    { "source": "/documental/", "destination": "/documentario", "permanent": true }
  ],
  "rewrites": [
    { "source": "/((?!assets/|__l5e/|robots.txt|sitemap.xml|~flock.js).*)", "destination": "/index.html" }
  ]
}
