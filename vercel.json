{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/((?!assets/|__l5e/|robots\\.txt|sitemap\\.xml|~flock\\.js|sw\\.js|.*\\.webmanifest).*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/documental",
      "destination": "/documentario",
      "permanent": true
    },
    {
      "source": "/documental/",
      "destination": "/documentario",
      "permanent": true
    },
    {
      "source": "/apoie",
      "destination": "/comunidade",
      "permanent": true
    },
    {
      "source": "/apoie/",
      "destination": "/comunidade",
      "permanent": true
    },
    {
      "source": "/equipe",
      "destination": "/sobre",
      "permanent": true
    },
    {
      "source": "/equipe/",
      "destination": "/sobre",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!assets/|__l5e/|robots.txt|sitemap.xml|~flock.js).*)",
      "destination": "/index.html"
    }
  ]
}
